---
import BaseLayout from "../layouts/BaseLayout.astro";

const skills = [
  { category: "Languages", items: ["Python", "TypeScript", "JavaScript", "C#", "C++"] },
  { category: "Backend", items: ["FastAPI", "Flask", "Node.js", ".NET"] },
  { category: "Frontend", items: ["Astro", "React", "Tailwind CSS"] },
  { category: "Infrastructure", items: ["Pulumi", "Docker", "Nginx", "Linux"] },
  { category: "Cloud", items: ["AWS", "GCS", "Hetzner", "delta.blue"] },
  { category: "Data", items: ["PostgreSQL", "pandas"] },
  { category: "IoT", items: ["ESP32", "Raspberry Pi", "MQTT", "KiCad"] },
];
---

<BaseLayout title="About — André Weigel" description="About André Weigel — developer and photographer based in Germany.">
  <div class="py-8">
    <h1 class="text-3xl font-semibold mb-10">About</h1>

    <!-- Bio -->
    <section class="mb-12">
      <!-- TODO: Add your photo — place it at public/images/photo.jpg and uncomment below -->
      <!--
      <img
        src="/images/photo.jpg"
        alt="André Weigel"
        class="w-28 h-28 rounded-full object-cover mb-8 grayscale hover:grayscale-0 transition-all"
      />
      -->

      <div class="space-y-4 text-neutral-700 dark:text-neutral-300 leading-relaxed">
        <!-- TODO: Replace with your own bio -->
        <p>
          Hey, I'm André, a mechanical engineer, developer, and photographer based in Germany, born and raised in Évora, Portugal.
          I’ve mostly been working in the rail/transport space.
          I'm interested in building useful things (sometimes also pointless things).
        </p>
        <p>
          I’m really into public transportation and how it can make cities more fair, more livable, and less dependent on cars.
           I’ve done work with <a href="https://www.bahn.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] underline">Deutsche Bahn</a>, 
           <a href="https://www.bvg.de" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] underline">BVG Berlin</a>, 
           <a href="https://www.alstom.com/alstom-austria" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] underline">Alstom</a>, and the 
           <a href="https://www.gov.uk/government/organisations/department-for-transport" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] underline">UK Department for Transport</a>.
        <p>
          Currently working at <a href="https://incrementalsolutions.co.uk/" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] underline">Incremental Solutions</a>, a railway solutions company based in York.
        </p>
      </div>
    </section>
    
    <!-- Interests -->
    <section>
      <h2 class="text-lg font-semibold mb-4">Interests</h2>
      <p class="text-neutral-700 dark:text-neutral-300 leading-relaxed">
        I'm drawn to systems and how they connect — <span class="text-[var(--color-accent)]">public transport</span>, <span class="text-[var(--color-accent)]">self-hosting</span>, <span class="text-[var(--color-accent)]">open source</span>, <span class="text-[var(--color-accent)]">self-sustainability</span>, <span class="text-[var(--color-accent)]">agriculture</span>, <span class="text-[var(--color-accent)]">energy</span>, <span class="text-[var(--color-accent)]">local infrastructure</span>, <span class="text-[var(--color-accent)]">film photography</span>. Anything that gives people more ownership over the things they depend on.
      </p>
    </div>
    </section>
    
    <!-- Skills -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold mb-6">Skills & tools</h2>
      <div class="space-y-4">
        {skills.map(({ category, items }) => (
          <div class="flex flex-col sm:flex-row sm:items-baseline gap-2">
            <span class="text-sm text-neutral-500 dark:text-neutral-400 sm:w-32 shrink-0">{category}</span>
            <div class="flex flex-wrap gap-1.5">
              {items.map((item) => (
                <span class="text-sm px-2.5 py-1 rounded-full bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Photography -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold mb-4">Photography</h2>
      <p class="text-neutral-700 dark:text-neutral-300 leading-relaxed">
        I shoot mostly film — 35mm and medium format. You can find my photos at{" "}
        <a
          href="https://www.youtube.com/watch?v=ZIYIm7lgUJU"
          target="_blank"
          rel="noopener"
          class="text-[var(--color-accent)] hover:underline"
        >
          photos.andreweigel.me</a>.
        <!-- TODO: Update if the URL is different, or remove if not ready yet -->
      </p>
    </section>

  </div>
</BaseLayout>
