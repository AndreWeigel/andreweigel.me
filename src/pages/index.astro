---
import BaseLayout from "../layouts/BaseLayout.astro";
import LayeredSprite from "../components/LayeredSprite.astro";
---

<BaseLayout title="André Weigel">
  <section class="py-16">
    <div class="flex items-start gap-8">
      <div class="shrink-0 hidden sm:block">
        <LayeredSprite
          layers={[
            { name: "andre_head", tag: "idle", hoverTag: "tongue" },
            { name: "andre_tongue", tag: "idle", hoverTag: "tongue" },
            { names: ["andre_cap_blue", "andre_cap_bege", "andre_hat_black", "andre_fez","andre_no_hat"], tag: "idle", hoverTag: "tongue" },
          ]}
          scale={3}
        />
      </div>
      <div>
        <p class="text-sm text-[var(--color-accent)] font-medium mb-3 uppercase tracking-widest">Hi there, I'm</p>
        <h1 class="text-4xl font-semibold mb-4">André Weigel</h1>
        <p class="text-xl text-neutral-600 dark:text-neutral-400 max-w-xl">
          <!-- TODO: Write your one-liner here -->
          Engineer, Developer & tinkerer based in Berlin. I build things, mess around with technology, and occasionally shoot film.
        </p>
      </div>
    </div>
    <div class="flex gap-4 mt-8">
      <a href="/about" class="px-4 py-2 rounded-lg bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-dark)] transition-colors">
        hire me
      </a>
      <a href="/projects" class="px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-700 text-sm font-medium hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors">
        or check out my projects
      </a>
    </div>
  </section>
</BaseLayout>
